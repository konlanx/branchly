{
  "name": "@branchly/datasource-mysql",
  "version": "0.1.5",
  "description": "MySQL datasource adapter for branchly (per-branch databases, SQL-level cloning).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@branchly/adapter-test-kit": "workspace:*",
    "branchly": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konlanx/branchly.git",
    "directory": "packages/datasource-mysql"
  },
  "homepage": "https://github.com/konlanx/branchly#readme",
  "bugs": "https://github.com/konlanx/branchly/issues"
}
