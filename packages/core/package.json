{
  "name": "branchly",
  "version": "0.1.17",
  "description": "Keep each VCS branch paired with its own database state.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "branchly": "./dist/cli.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "node ../../scripts/sync-readme.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "cross-spawn": "^7.0.6",
    "jiti": "^2.4.2"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konlanx/branchly.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/konlanx/branchly#readme",
  "bugs": "https://github.com/konlanx/branchly/issues"
}
